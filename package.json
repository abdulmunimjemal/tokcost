{
  "name": "tokcost",
  "version": "0.1.0",
  "description": "An instant, offline token + cost counter for LLM text.",
  "keywords": [
    "tokens",
    "tokenizer",
    "tiktoken",
    "llm",
    "gpt",
    "cost",
    "cli"
  ],
  "type": "module",
  "bin": {
    "tokcost": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "author": "Abdulmunim Jemal",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abdulmunimjemal/tokcost.git"
  },
  "homepage": "https://oss.munim.io/tokcost/",
  "bugs": {
    "url": "https://github.com/abdulmunimjemal/tokcost/issues"
  },
  "dependencies": {
    "gpt-tokenizer": "^3.4.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "typescript": "^6.0.0",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
